# OpenClaw Gateway
OPENCLAW_PORT=18789
OPENCLAW_TOKEN=your-gateway-token-here

# LiteLLM Proxy
LITELLM_PORT=4000
LITELLM_MASTER_KEY=your-litellm-key

# Vertex AI (Google Cloud)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=global

# OpenRouter (fallback)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Mission Control
MC_API_URL=http://localhost:8000
MC_TOKEN=your-mc-token

# Ollama (local)
OLLAMA_HOST=http://localhost:11434

# WordPress (if using blog pipeline)
WP_URL=https://your-site.com/blog/wp-json/wp/v2
WP_USER=your-wp-user
WP_APP_PASSWORD=your-app-password
