---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const useCases = await getCollection('use-cases');
const base = import.meta.env.BASE_URL;
---

<Base title="Use Cases — OpenClaw Learnings">
  <div class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-black mb-4">Use Cases</h1>
    <p class="text-text-muted text-lg mb-12">Real projects running on this stack right now.</p>

    <div class="space-y-4">
      {useCases.map(entry => (
        <a href={`${base}use-cases/${entry.id}/`} class="group block p-6 bg-surface-raised border border-border rounded-xl hover:border-accent/50 transition-all">
          <h2 class="font-bold text-xl group-hover:text-accent transition-colors">{entry.data.title}</h2>
        </a>
      ))}
    </div>
  </div>
</Base>
