---
import { getCollection, render } from 'astro:content';
import Article from '../../layouts/Article.astro';

const pages = await getCollection('pages');
const entry = pages.find(p => p.id.includes('quick-start'))!;
const { Content } = await render(entry);
---

<Article title={entry.data.title} description="Go from zero to a working multi-agent system in a weekend.">
  <Content />
</Article>
