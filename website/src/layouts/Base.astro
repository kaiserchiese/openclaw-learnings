---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '21 AI agents. 50+ cron jobs. $7/month. One Windows server.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-surface/80 backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href={base} class="flex items-center gap-2 font-bold text-lg text-text hover:text-accent transition-colors">
          <span class="text-accent font-mono text-sm">⟁</span>
          OpenClaw Learnings
        </a>
        <div class="flex items-center gap-6 text-sm text-text-muted">
          <a href={`${base}patterns/`} class="hover:text-accent transition-colors">Patterns</a>
          <a href={`${base}use-cases/`} class="hover:text-accent transition-colors">Use Cases</a>
          <a href={`${base}quick-start/`} class="hover:text-accent transition-colors">Quick Start</a>
          <a href={`${base}timeline/`} class="hover:text-accent transition-colors">Timeline</a>
          <a href="https://github.com/kaiserchiese/openclaw-learnings" target="_blank" class="hover:text-accent transition-colors">GitHub</a>
        </div>
      </div>
    </nav>

    <main class="pt-14">
      <slot />
    </main>

    <footer class="border-t border-border mt-24 py-12 text-center text-text-muted text-sm">
      <div class="max-w-6xl mx-auto px-6">
        <p>Built by <a href="https://github.com/kaiserchiese" target="_blank">Pio Iglesias</a> with <a href="https://github.com/openclaw" target="_blank">OpenClaw</a> + <a href="https://claude.ai/claude-code" target="_blank">Claude Code</a></p>
        <p class="mt-2 text-text-muted/60">MIT License — Use anything here however you want</p>
      </div>
    </footer>
  </body>
</html>
